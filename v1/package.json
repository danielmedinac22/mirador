{
  "name": "mirador-cli-v1-dev",
  "private": true,
  "version": "1.0.0-dev.0",
  "description": "Mirador v1 — collaborative artifacts on git, brain-aware Claude Code sessions.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mirador-v1": "./dist/index.js"
  },
  "files": ["dist", "themes", "templates", "scripts", "skill"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node20 --shims --no-splitting --clean",
    "dev": "tsup src/index.ts --format esm --target node20 --shims --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.0.0",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
